{
	"extends": "ts-config/jsx.json",
	"compilerOptions": {
		"types": ["node", "vite/client"],
		"baseUrl": "src",
		"paths": {
			"~/*": ["src/*"],
			"~/routes/*": ["src/routes/*"],
			"~/components/*": ["src/components/*"],
			"~/layouts/*": ["src/layouts/*"]
		}
	},
	"files": ["./.eslintrc.cjs"],
	"exclude": ["node_modules"],
	"include": ["src"]
}
