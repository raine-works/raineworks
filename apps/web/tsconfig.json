{
	"extends": "ts-config/jsx.json",
	"compilerOptions": {
		"types": ["node", "vite/client"],
		"baseUrl": ".",
		"paths": {
			"~/*": ["src/*"],
			"~/routes/*": ["src/routes/*"],
			"~/components/*": ["src/components/*"]
		}
	},
	"files": ["./.eslintrc.cjs"],
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
