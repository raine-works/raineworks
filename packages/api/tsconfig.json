{
	"extends": "@raineworks/tsconfig/react-library.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./.types/tsconfig.tsbuildinfo",
		"paths": {
			"@api/*": ["./src/*"],
			"@ui/*": ["../ui/src/*"],
			"@raineworks/ui/*": ["../ui/src/*"],
			"@server/*": ["../server/src/*"],
			"@database/*": ["../database/src/*"],
			"@tools/*": ["../tools/src/*"]
		}
	},
	"include": [
		"src",
		"../ui/src",
		"../server/src",
		"../database/src",
		"../tools/src"
	]
}
