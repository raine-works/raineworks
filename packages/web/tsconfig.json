{
	"extends": "@raineworks/tsconfig/react-app.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./.types/tsconfig.tsbuildinfo",
		"paths": {
			"@web/*": ["./src/*"],
			"@api/*": ["../api/src/*"],
			"@server/*": ["../server/src/*"],
			"@database/*": ["../database/src/*"],
			"@ui/*": ["../ui/src/*"]
		}
	},
	"include": ["src", "vite-env.d.ts"]
}
